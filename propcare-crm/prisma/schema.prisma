// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
//  ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  AGENT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  PENDING_CLIENT
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketCategory {
  MAINTENANCE
  COMPLAINT
  INQUIRY
  PAYMENT
  LEASE
  HANDOVER
  OTHER
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL_SENT
  NEGOTIATION
  WON
  LOST
}

enum PropertyType {
  APARTMENT
  VILLA
  TOWNHOUSE
  PENTHOUSE
  STUDIO
  DUPLEX
  COMMERCIAL
}

enum PropertyStatus {
  AVAILABLE
  RESERVED
  SOLD
  RENTED
  UNDER_MAINTENANCE
}

enum InteractionType {
  CALL
  EMAIL
  WHATSAPP
  MEETING
  SITE_VISIT
  NOTE
}

enum NotificationType {
  TICKET_ASSIGNED
  TICKET_UPDATED
  TICKET_RESOLVED
  LEAD_ASSIGNED
  MENTION
  SYSTEM
}

// ─────────────────────────────────────────────
//  MODELS
// ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  supabaseId    String    @unique @map("supabase_id")
  email         String    @unique
  name          String
  avatar        String?
  phone         String?
  role          UserRole  @default(AGENT)
  department    String?
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  assignedTickets   Ticket[]       @relation("AssignedAgent")
  createdTickets    Ticket[]       @relation("CreatedBy")
  ticketComments    TicketComment[]
  assignedLeads     Lead[]         @relation("AssignedAgent")
  interactions      Interaction[]
  notifications     Notification[]
  activities        ActivityLog[]

  @@map("users")
}

model Property {
  id            String         @id @default(cuid())
  code          String         @unique
  name          String
  type          PropertyType
  status        PropertyStatus @default(AVAILABLE)
  project       String?
  building      String?
  floor         Int?
  unit          String?
  area          Float?
  bedrooms      Int?
  bathrooms     Int?
  price         Float?
  address       String?
  city          String?
  description   String?
  images        String[]
  amenities     String[]
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  // Relations
  tickets       Ticket[]
  leads         Lead[]
  clients       ClientProperty[]

  @@map("properties")
}

model Client {
  id            String    @id @default(cuid())
  code          String    @unique
  name          String
  email         String?
  phone         String
  whatsapp      String?
  nationality   String?
  idNumber      String?   @map("id_number")
  address       String?
  city          String?
  notes         String?
  tags          String[]
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  tickets       Ticket[]
  leads         Lead[]
  interactions  Interaction[]
  properties    ClientProperty[]

  @@map("clients")
}

model ClientProperty {
  id          String    @id @default(cuid())
  clientId    String    @map("client_id")
  propertyId  String    @map("property_id")
  relation    String    // owner, tenant, prospect
  since       DateTime?
  notes       String?
  createdAt   DateTime  @default(now()) @map("created_at")

  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  property    Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([clientId, propertyId])
  @@map("client_properties")
}

model Ticket {
  id            String         @id @default(cuid())
  code          String         @unique
  title         String
  description   String
  status        TicketStatus   @default(OPEN)
  priority      TicketPriority @default(MEDIUM)
  category      TicketCategory @default(OTHER)
  
  clientId      String?        @map("client_id")
  propertyId    String?        @map("property_id")
  assignedToId  String?        @map("assigned_to_id")
  createdById   String         @map("created_by_id")

  dueDate       DateTime?      @map("due_date")
  resolvedAt    DateTime?      @map("resolved_at")
  closedAt      DateTime?      @map("closed_at")
  
  attachments   String[]
  tags          String[]
  
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  // Relations
  client        Client?        @relation(fields: [clientId], references: [id])
  property      Property?      @relation(fields: [propertyId], references: [id])
  assignedTo    User?          @relation("AssignedAgent", fields: [assignedToId], references: [id])
  createdBy     User           @relation("CreatedBy", fields: [createdById], references: [id])
  comments      TicketComment[]
  history       TicketHistory[]

  @@map("tickets")
}

model TicketComment {
  id          String    @id @default(cuid())
  ticketId    String    @map("ticket_id")
  userId      String    @map("user_id")
  content     String
  isInternal  Boolean   @default(false) @map("is_internal")
  attachments String[]
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  ticket      Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id])

  @@map("ticket_comments")
}

model TicketHistory {
  id          String    @id @default(cuid())
  ticketId    String    @map("ticket_id")
  field       String
  oldValue    String?   @map("old_value")
  newValue    String?   @map("new_value")
  changedById String    @map("changed_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")

  ticket      Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@map("ticket_history")
}

model Lead {
  id            String      @id @default(cuid())
  code          String      @unique
  title         String?
  status        LeadStatus  @default(NEW)
  source        String?
  budget        Float?
  
  clientId      String?     @map("client_id")
  propertyId    String?     @map("property_id")
  assignedToId  String?     @map("assigned_to_id")
  
  notes         String?
  tags          String[]
  followUpDate  DateTime?   @map("follow_up_date")
  
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  client        Client?     @relation(fields: [clientId], references: [id])
  property      Property?   @relation(fields: [propertyId], references: [id])
  assignedTo    User?       @relation("AssignedAgent", fields: [assignedToId], references: [id])
  interactions  Interaction[]

  @@map("leads")
}

model Interaction {
  id          String          @id @default(cuid())
  type        InteractionType
  summary     String
  details     String?
  duration    Int?            // in minutes
  
  clientId    String?         @map("client_id")
  leadId      String?         @map("lead_id")
  userId      String          @map("user_id")
  
  scheduledAt DateTime?       @map("scheduled_at")
  createdAt   DateTime        @default(now()) @map("created_at")

  client      Client?         @relation(fields: [clientId], references: [id])
  lead        Lead?           @relation(fields: [leadId], references: [id])
  user        User            @relation(fields: [userId], references: [id])

  @@map("interactions")
}

model Notification {
  id          String           @id @default(cuid())
  userId      String           @map("user_id")
  type        NotificationType
  title       String
  message     String
  link        String?
  isRead      Boolean          @default(false) @map("is_read")
  createdAt   DateTime         @default(now()) @map("created_at")

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model ActivityLog {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  action      String
  entity      String
  entityId    String    @map("entity_id")
  metadata    Json?
  createdAt   DateTime  @default(now()) @map("created_at")

  user        User      @relation(fields: [userId], references: [id])

  @@map("activity_logs")
}
